# YAAM — production ENV шаблон для PostgreSQL-стороны (server.postgresql.js).
#
# Production Switch — Stage 9. ЭТОТ ФАЙЛ — ШАБЛОН, ПОДГОТОВЛЕННЫЙ БЕЗ
# ДОСТУПА К РЕАЛЬНОМУ VPS. Ни одно значение здесь не проверено против
# реальной инфраструктуры — заполните и адаптируйте под конкретный сервер,
# затем скопируйте как /opt/yaam/server/.env.postgresql (см.
# server/docs/postgresql-deployment-runbook.md).
#
# НЕ ПУТАТЬ с server/.env.example — тот для SQLite-стороны (server.js),
# который остаётся ЕДИНСТВЕННЫМ реально работающим production-путём на
# сегодня (yaam.su). Этот файл — для будущего server.postgresql.js
# (изолирован, никогда не запускается автоматически).

# --- Приложение -------------------------------------------------------

# local | staging | production
APP_ENV=production

# production включает: (а) запрет dev-платёжных маршрутов, (б) обязательный
# TRUST_PROXY=loopback (см. ниже), (в) generic-сообщения об ошибках без
# stack trace клиенту, (г) NODE_ENV=production также отключает localhost в
# CORS-allowlist (config/cors.js).
NODE_ENV=production

PG_HEALTH_PORT=3001
PG_HEALTH_HOST=127.0.0.1

# --- PostgreSQL (production database) ----------------------------------
#
# Отдельная production БД, отдельный пользователь с МИНИМАЛЬНЫМИ правами
# (см. postgresql-deployment-runbook.md, раздел "PostgreSQL setup") — НЕ
# суперпользователь, НЕ владелец кластера. Пример (заполнить реальными
# значениями):
#   DATABASE_URL=postgres://yaam_app:СЛОЖНЫЙ_ПАРОЛЬ@127.0.0.1:5432/yaam_production
#
# Альтернатива — дискретные переменные вместо DATABASE_URL (db/postgresql/
# bootstrap.js validateEnv() принимает любой из двух вариантов):
DATABASE_URL=
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=yaam_production
# PGUSER=yaam_app
# PGPASSWORD=

# PostgreSQL слушает только на loopback (см. runbook) — TLS между
# приложением и локальным PostgreSQL на том же хосте избыточен; если
# PostgreSQL когда-либо переедет на отдельный хост — обязательно true.
PG_SSL=false

# Пул подключений — дефолты (db/postgresql/index.js) обычно достаточны для
# одного backend-процесса; трогать только по реальным метрикам нагрузки.
# PG_POOL_MAX=10
# PG_POOL_IDLE_TIMEOUT_MS=30000
# PG_POOL_CONNECT_TIMEOUT_MS=5000

# --- CORS ----------------------------------------------------------------

# Через запятую. Если не задано — дефолт https://yaam.su,https://www.yaam.su
# (см. config/cors.js) — обычно достаточно, оставить пустым.
CORS_ALLOWED_ORIGINS=

# --- Trust proxy (Production Switch Stage 9) ------------------------------
#
# ОБЯЗАТЕЛЬНО "loopback" при APP_ENV=production — иначе приложение
# откажется стартовать (fail-closed, services/postgresql/app.js
# validateAppEnv()). Единственная поддерживаемая топология — один Nginx на
# том же VPS перед одним backend-процессом (не CDN/несколько прокси в
# цепочке — тогда потребуется отдельный пересмотр, не просто "true").
#
# ПЕРЕД включением YOOKASSA_WEBHOOK_ENFORCE_IP_ALLOWLIST (ниже) — ОБЯЗАТЕЛЬНО
# подтвердить на реальном сервере, что Nginx корректно передаёт
# X-Forwarded-For и что req.ip в приложении отражает реальный внешний IP,
# а не адрес Nginx (см. runbook, раздел "Trust Proxy validation").
TRUST_PROXY=loopback

# --- Платежи (ЮKassa) ------------------------------------------------------

# mock (демо, без реальных денег) | yookassa
PAYMENT_PROVIDER=mock

# Заполнить ТОЛЬКО тестовыми credentials. Провайдер и startup validation
# намеренно fail-closed: без sandbox/test_ значений приложение не запустится.
YOOKASSA_ENV=sandbox
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://yaam.su/
YOOKASSA_WEBHOOK_URL=https://api-pg.yaam.su/api/webhooks/payment

# Официальный IP-allowlist ЮKassa (Stage 8, services/paymentProviders/
# yookassaProvider.js) — ВЫКЛЮЧЕНО по умолчанию намеренно. Включать true
# ТОЛЬКО после того, как runbook'ом подтверждено, что TRUST_PROXY=loopback
# выше реально корректно резолвит req.ip на этом сервере (см. предыдущий
# раздел). До этого подтверждения канонический lookup (Stage 8,
# verifyWebhook) остаётся ЕДИНСТВЕННЫМ обязательным механизмом подлинности
# webhook — он не зависит от корректности прокси-цепочки.
YOOKASSA_WEBHOOK_ENFORCE_IP_ALLOWLIST=false

# Только для закрытого mock-staging — при APP_ENV=production маршрут не
# зарегистрируется, даже если здесь ошибочно true (routes/postgresql/api.js,
# тройной гейт: флаг + PAYMENT_PROVIDER=mock + APP_ENV in [local,staging]).
ENABLE_DEV_PAYMENT_ROUTES=false

# Таймауты сетевых вызовов провайдера, мс (опционально, дефолт 10000 у всех).
# PAYMENT_CREATE_TIMEOUT_MS=10000
# PAYMENT_STATUS_TIMEOUT_MS=10000
# PAYMENT_REFUND_TIMEOUT_MS=10000
# PAYMENT_GET_REFUND_TIMEOUT_MS=10000

# --- Админка ---------------------------------------------------------------

# Внутренняя админка YAAM (не портал самообслуживания ресторана). Оба
# значения обязательны вместе — иначе /admin вообще не монтируется.
ADMIN_USER=
ADMIN_PASS=

# --- Telegram-бот ресторана -------------------------------------------------

TELEGRAM_BOT_TOKEN=
