{
  "name": "yaam-server",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node db/seed.js",
    "backup": "node scripts/backup-db.js",
    "restore": "node scripts/restore-db.js",
    "test": "node --test test/*.test.js",
    "test:postgresql": "NODE_ENV=test node --test test/postgresql/*.test.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^8.5.2",
    "node-telegram-bot-api": "^1.1.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "embedded-postgres": "16.14.0-beta.17"
  }
}
