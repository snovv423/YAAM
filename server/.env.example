PORT=3000

# production | (не задано) — влияет на CORS: localhost разрешён только когда не production
NODE_ENV=

# Разрешённые origin для CORS через запятую. Если не задано — по умолчанию
# только https://yaam.su и https://www.yaam.su (см. server/config/cors.js).
# localhost/127.0.0.1 разрешён отдельно и всегда, пока NODE_ENV != production.
CORS_ALLOWED_ORIGINS=

# Платёжный провайдер: mock (по умолчанию, для разработки/демо) | yookassa (пока не реализован)
PAYMENT_PROVIDER=mock

# ЮKassa — заполнить, когда будете подключать реальную оплату
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Внутренняя админка YAAM (не для ресторанов!)
ADMIN_USER=
ADMIN_PASS=

# Токен бота ресторана от @BotFather
TELEGRAM_BOT_TOKEN=

# Путь к файлу SQLite (по умолчанию server/db/yaam.db)
DB_PATH=
