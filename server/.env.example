PORT=3000
HOST=127.0.0.1

# local | staging | production — собственный контур YAAM. В production
# обязательны безопасный reverse proxy и отключённые dev-payment маршруты.
APP_ENV=local

# production | (не задано) — влияет на CORS: localhost разрешён только когда не production
NODE_ENV=

# Разрешённые origin для CORS через запятую. Если не задано — по умолчанию
# только https://yaam.su и https://www.yaam.su (см. server/config/cors.js).
# localhost/127.0.0.1 разрешён отдельно и всегда, пока NODE_ENV != production.
CORS_ALLOWED_ORIGINS=

# SQLite-контур остаётся на mock. YooKassa Sandbox подключается только через
# PostgreSQL staging (`.env.postgresql.example`).
PAYMENT_PROVIDER=mock

# Только для закрытого mock-staging. По умолчанию false; при APP_ENV=production
# маршрут не зарегистрируется даже при ошибочном true.
ENABLE_DEV_PAYMENT_ROUTES=false

# За единственным локальным Nginx: loopback. Не используйте true/произвольные
# hop-count без отдельного пересмотра топологии reverse proxy.
TRUST_PROXY=

# Не добавляйте YooKassa credentials в этот SQLite env-файл.

# Внутренняя админка YAAM (не для ресторанов!)
ADMIN_USER=
ADMIN_PASS=

# Токен бота ресторана от @BotFather
TELEGRAM_BOT_TOKEN=

# Путь к файлу SQLite (по умолчанию server/db/yaam.db)
DB_PATH=
